    <div id="fullscreen-overlay" class="fixed inset-0 z-[200] bg-black opacity-0 pointer-events-none transition-opacity duration-500 flex flex-col items-center justify-center">
        <div class="absolute top-0 left-0 px-6 px-10 py-4 flex justify-between items-center z-10 w-full bg-linear-to-b from-black/50 to-transparent">
            <div id="fullscreen-info" class="font-sans text-[10px] uppercase tracking-[0.4em] text-white/50 font-bold"></div>
            <button onclick="closeFullscreen()" class="font-sans text-[10px] uppercase tracking-[0.4em] font-bold text-white/50 hover:text-white transition-all cursor-pointer flex items-center gap-4 group">
                <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300">Cerrar ventana</span>
                <span class="text-2xl font-light">✕</span>
            </button>
        </div>
        <div class="w-full h-full relative flex items-center justify-center overflow-hidden">
             <div id="fullscreen-track" class="flex transition-transform duration-700 cubic-bezier(0.16, 1, 0.3, 1) h-full w-full">
                 <!-- Photos injected here -->
             </div>
        </div>
    </div>

    <script src="app.js"></script>
</body>
</html>
