        <header id="main-header" class="h-[64px] px-6 lg:px-10 border-b border-gray-100 flex justify-between items-center fixed top-0 left-0 right-0 bg-white/95 backdrop-blur-md z-[100] transition-transform duration-500">
            <button onclick="showTab('tab-home')" class="text-xl font-bold tracking-tighter shrink-0">MIRADAS '26</button>
