                </div>
            </div>
            <div class="w-32 hidden md:block"></div> <!-- Spacer for symmetry -->
        </header>

        <main class="max-w-full mx-auto">
            <div id="main-split-container" class="flex flex-col lg:flex-row h-screen transition-all duration-700 ease-in-out">
                
                <!-- Columna Izquierda: Grid de Edificios -->
                <div id="grid-container" class="flex-1 h-full overflow-y-auto p-6 lg:p-10 pt-[80px] lg:pt-[100px] transition-all duration-700 scroll-smooth">
                    <div id="buildings-public-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-12">
                        <!-- Tarjetas inyectadas -->
                    </div>
                    
                    <!-- Mapa General (Solo en el listado) -->
                    <div id="general-map-container" class="mt-32 pb-20 space-y-12 animate-in fade-in duration-1000">
                        <div class="h-[1px] w-full bg-gray-100"></div>
                        <h2 class="text-6xl font-bold tracking-tight text-center">Cartografía del Patrimonio</h2>
                        <div id="map-general" class="h-[600px] w-full shadow-inner bg-gray-50 border border-gray-100 rounded-[3rem]"></div>
                        <p class="font-sans text-[10px] uppercase tracking-widest text-gray-400 text-center">Explora la distribución espacial de los hitos arquitectónicos</p>
                    </div>
                </div>
 
                <!-- Resizer Handle (Minimal) -->
                <div id="split-resizer" class="hidden lg:flex w-1 hover:w-1.5 bg-gray-100 hover:bg-black cursor-col-resize transition-all z-50 items-center justify-center group active:bg-black">
                    <div class="h-32 w-px bg-black/5 group-hover:bg-white/20"></div>
