<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Proyecto Miradas 2026</title>
    <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@100..900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Cormorant Garamond', serif; }
        .font-sans { font-family: 'Inter', sans-serif; }
        .font-display { font-family: 'Playfair Display', serif; }
        #map-general, #map-detail { border-radius: 1rem; filter: grayscale(1) contrast(1.1); }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .welcome-bg { 
            background: linear-gradient(rgba(253, 253, 251, 0.95), rgba(253, 253, 251, 0.8)), 
                        url('https://upload.wikimedia.org/wikipedia/commons/e/ea/Plano_de_la_Ciudad_de_Buenos_Aires_-_1900.jpg') center/cover;
            background-blend-mode: grayscale;
        }
        .retro-overlay {
            position: fixed;
            inset: 0;
            pointer-events: none;
            background: url('https://www.transparenttextures.com/patterns/natural-paper.png');
            opacity: 0.15;
            z-index: 1000;
        }
    </style>
</head>
<body class="bg-white text-black">
    <div class="retro-overlay"></div>
 
    <!-- PANTALLA DE BIENVENIDA -->
    <section id="tab-home" class="tab-content active h-screen flex flex-col items-center justify-center text-center welcome-bg px-6">
        <div class="space-y-4 mb-12 pt-20">
            <h1 id="main-title" class="text-[clamp(4rem,20vw,12rem)] font-bold tracking-tighter leading-[0.8] text-black flex justify-center select-none">
                <span class="letter group relative" data-letter="M" style="--img: url('https://picsum.photos/seed/m-arch/400/600?grayscale')">M</span>
                <span class="letter group relative" data-letter="I" style="--img: url('https://picsum.photos/seed/i-arch/400/600?grayscale')">I</span>
                <span class="letter group relative" data-letter="R" style="--img: url('https://picsum.photos/seed/r-arch/400/600?grayscale')">R</span>
                <span class="letter group relative" data-letter="A" style="--img: url('https://picsum.photos/seed/a-arch/400/600?grayscale')">A</span>
                <span class="letter group relative" data-letter="D" style="--img: url('https://picsum.photos/seed/d-arch/400/600?grayscale')">D</span>
                <span class="letter group relative" data-letter="A" style="--img: url('https://picsum.photos/seed/a2-arch/400/600?grayscale')">A</span>
                <span class="letter group relative" data-letter="S" style="--img: url('https://picsum.photos/seed/s-arch/400/600?grayscale')">S</span>
            </h1>

            <style>
                .letter {
                    position: relative;
                    color: #000;
                    transition: color 0.3s;
                }
                .letter::before {
                    content: attr(data-letter);
                    position: absolute;
                    inset: 0;
                    color: transparent;
                    background-image: var(--img);
                    background-size: cover;
                    background-position: center;
                    -webkit-background-clip: text;
                    background-clip: text;
                    opacity: 0;
                    transition: opacity 0.5s;
                    pointer-events: none;
                    /* Mask that follows the mouse via CSS variables */
                    -webkit-mask-image: radial-gradient(circle 120px at var(--mouse-x, 50%) var(--mouse-y, 50%), black 0%, transparent 100%);
                    mask-image: radial-gradient(circle 120px at var(--mouse-x, 50%) var(--mouse-y, 50%), black 0%, transparent 100%);
                }
                .letter:hover {
                    color: rgba(0,0,0,0.1);
                }
                .letter:hover::before {
                    opacity: 1;
                }
            </style>

            <script>
                document.getElementById('main-title').addEventListener('mousemove', (e) => {
                    const letters = e.currentTarget.querySelectorAll('.letter');
                    letters.forEach(letter => {
                        const rect = letter.getBoundingClientRect();
                        const x = e.clientX - rect.left;
                        const y = e.clientY - rect.top;
                        letter.style.setProperty('--mouse-x', `${x}px`);
                        letter.style.setProperty('--mouse-y', `${y}px`);
                    });
                });
            </script>
            <div class="h-px w-32 bg-black/10 mx-auto"></div>
            <p class="text-sm md:text-lg opacity-40 italic font-sans uppercase tracking-[0.6em]">Patrimonio Arquitectónico de Buenos Aires</p>
